# Shared editor baseline across the fleet (degner / oto / balanze / norrix).
# 4-space default; 2-space only where the language's formatter or ecosystem
# convention is firmly 2 (web stack, YAML, Dart). LF everywhere (matching
# .gitattributes); trailing whitespace trimmed except in Markdown (hard
# line breaks are syntax there).
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[*.{js,mjs,cjs,ts,svelte,json,jsonc,html,css,scss,yml,yaml,dart}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

# --- Repo-specific overrides below this line ---

# Generated lockfiles shouldn't be reformatted by an editor save.
[{Cargo.lock,bun.lock}]
insert_final_newline = unset
trim_trailing_whitespace = unset
