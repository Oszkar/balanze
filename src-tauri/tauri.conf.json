{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Balanze",
  "version": "0.4.2",
  "identifier": "me.oszkar.balanze",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Balanze",
        "width": 360,
        "height": 560,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "visible": false,
        "skipTaskbar": true,
        "shadow": false
      }
    ],
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": false,
      "showMenuOnLeftClick": false,
      "tooltip": "Balanze"
    },
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Local-first AI usage tracker",
    "longDescription": "Tray-first desktop utility that monitors Claude (subscription + API) and OpenAI usage in one normalized view. Win + Mac."
  }
}
